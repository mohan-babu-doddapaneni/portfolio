# Build settings tuned for security & a strict Content-Security-Policy.

# Emit the webpack runtime as an external file instead of an inline <script>,
# so the CSP can use "script-src 'self'" (no 'unsafe-inline' needed).
INLINE_RUNTIME_CHUNK=false

# Don't publish source maps — keeps the original source from being trivially
# reconstructed from the deployed bundle.
GENERATE_SOURCEMAP=false
